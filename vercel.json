{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/login.html", "destination": "/public/login.html" },
    { "source": "/index.html", "destination": "/public/index.html" },
    { "source": "/projetos.html", "destination": "/public/projetos.html" },
    { "source": "/projeto-detalhe.html", "destination": "/public/projeto-detalhe.html" },
    { "source": "/usuarios.html", "destination": "/public/usuarios.html" },
    { "source": "/relatorios.html", "destination": "/public/relatorios.html" },
    { "source": "/js/(.*)", "destination": "/public/js/$1" },
    { "source": "/", "destination": "/public/login.html" }
  ]
}
